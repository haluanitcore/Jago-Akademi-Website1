# ─── App ───────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3004
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/jago_akademi

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
WEB_URL=http://localhost:3004
COOKIE_SECURE=false
REFRESH_COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:3004

# ─── Payment (DOKU) ────────────────────────────────────
DOKU_CLIENT_ID=your-doku-client-id
DOKU_SECRET_KEY=your-doku-secret-key
DOKU_IS_PRODUCTION=false

# ─── Storage (Cloudflare R2) ───────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=jago-akademi
CLOUDFLARE_R2_PUBLIC_URL=https://pub.jagoakademi.com

# ─── Video (Cloudflare Stream) ─────────────────────────
CLOUDFLARE_STREAM_TOKEN=your-stream-token
CLOUDFLARE_STREAM_ACCOUNT=your-account-id

# ─── Email ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@jagoakademi.com
EMAIL_FROM_NAME=Jago Akademi

# ─── WhatsApp (vendor TBD) ─────────────────────────────
FONNTE_TOKEN=your-fonnte-token
WA_NUMBER=6281234567890

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Search ────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-master-key

# ─── Monitoring ────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token
