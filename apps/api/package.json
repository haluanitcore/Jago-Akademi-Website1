{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "lint": "eslint src --max-warnings 0",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sentry/node": "^10.60.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "5.79.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "4.22.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "8.1.0",
    "ioredis": "5.9.3",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.58.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pino": "10.0.0",
    "pino-http": "11.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "5.9.2",
    "vitest": "4.1.9"
  }
}
