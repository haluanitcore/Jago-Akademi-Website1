datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  authProvider String    @default("email")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      UserProfile?
  roles        UserRole[]
  courses      Course[]             @relation("TrainerCourses")
  enrollments  CourseEnrollment[]
  orders       Order[]
  certificates Certificate[]
  affiliate    Affiliate?
  referred     AffiliateCommission[] @relation("ReferredUserRelation")

  @@map("users")
}

model UserProfile {
  userId    String   @id
  phone     String?
  bio       String?  @db.Text
  headline  String?
  linkedin  String?
  location  String?
  expertise String[]
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      String
  tenantId  String?
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, tenantId])
  @@map("user_roles")
}

model CourseCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  iconUrl   String?
  sortOrder Int      @default(0)
  courses   Course[]

  @@map("course_categories")
}

model Course {
  id            String          @id @default(uuid())
  slug          String          @unique
  title         String
  description   String?         @db.Text
  shortDesc     String?
  price         Decimal         @default(0.00) @db.Decimal(12, 2)
  salePrice     Decimal?        @db.Decimal(12, 2)
  status        String          @default("draft") // draft, published
  trainerId     String
  categoryId    String?
  level         String?         // beginner, intermediate, advanced
  language      String          @default("id")
  thumbnailUrl  String?
  previewVideo  String?
  totalDuration Int             @default(0)
  totalLessons  Int             @default(0)
  totalEnrolled Int             @default(0)
  avgRating     Decimal         @default(0.00) @db.Decimal(3, 2)
  totalReviews  Int             @default(0)
  isFeatured    Boolean         @default(false)
  metaTitle     String?
  metaDesc      String?         @db.Text
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  category    CourseCategory?    @relation(fields: [categoryId], references: [id])
  trainer     User               @relation("TrainerCourses", fields: [trainerId], references: [id])
  sections    CourseSection[]
  enrollments CourseEnrollment[]
  certificates Certificate[]

  @@map("courses")
}

model CourseSection {
  id        String         @id @default(uuid())
  courseId  String
  title     String
  sortOrder Int            @default(0)
  lessons   CourseLesson[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_sections")
}

model CourseLesson {
  id          String   @id @default(uuid())
  sectionId   String
  title       String
  type        String   // video, text, quiz, assignment
  contentUrl  String?
  contentText String?  @db.Text
  duration    Int      @default(0)
  isPreview   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  section  CourseSection            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress CourseLessonProgress[]

  @@map("course_lessons")
}

model CourseEnrollment {
  id           String                 @id @default(uuid())
  courseId     String
  userId       String
  orderId      String?
  progressPct  Decimal                @default(0.00) @db.Decimal(5, 2)
  isCompleted  Boolean                @default(false)
  completedAt  DateTime?
  enrolledAt   DateTime               @default(now())
  progress     CourseLessonProgress[]

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@map("course_enrollments")
}

model CourseLessonProgress {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  watchedPct   Decimal   @default(0.00) @db.Decimal(5, 2)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     CourseLesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@map("course_lesson_progress")
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  totalAmount    Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @default(0.00) @db.Decimal(12, 2)
  finalAmount    Decimal     @db.Decimal(12, 2)
  status         String      @default("pending") // pending, paid, expired, cancelled
  paymentMethod  String?
  couponId       String?
  referralCode   String?
  paidAt         DateTime?
  expiredAt      DateTime?
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  items        OrderItem[]
  transactions PaymentTransaction[]
  commissions  AffiliateCommission[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  itemType   String  // course, event, ebook, marketplace, trainer_program, lms
  itemId     String
  itemTitle  String?
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  orderId       String
  gateway       String
  gatewayTxId   String?
  paymentMethod String?
  amount        Decimal  @db.Decimal(12, 2)
  status        String   @default("pending")
  gatewayRaw    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payment_transactions")
}

model Certificate {
  id        String   @id @default(uuid())
  code      String   @unique
  type      String   // course, event, trainer
  userId    String
  courseId  String?
  eventId   String?
  issuedAt  DateTime @default(now())
  fileUrl   String?
  isValid   Boolean  @default(true)
  metadata  Json?

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

model Affiliate {
  id               String   @id @default(uuid())
  userId           String   @unique
  code             String   @unique
  totalClicks      Int      @default(0)
  totalConversions Int      @default(0)
  totalEarnings    Decimal  @default(0.00) @db.Decimal(12, 2)
  balance          Decimal  @default(0.00) @db.Decimal(12, 2)
  commissionRate   Decimal  @default(10.00) @db.Decimal(5, 2)
  status           String   @default("active")
  joinedAt         DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id])
  commissions AffiliateCommission[]

  @@map("affiliates")
}

model AffiliateCommission {
  id            String    @id @default(uuid())
  affiliateId   String
  orderId       String
  referredUserId String
  commissionPct Decimal   @db.Decimal(5, 2)
  grossAmount   Decimal   @db.Decimal(12, 2)
  commissionAmt Decimal   @db.Decimal(12, 2)
  status        String    @default("pending") // pending, settled
  createdAt     DateTime  @default(now())
  settledAt     DateTime?

  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])
  order        Order     @relation(fields: [orderId], references: [id])
  referredUser User      @relation("ReferredUserRelation", fields: [referredUserId], references: [id])

  @@map("affiliate_commissions")
}
